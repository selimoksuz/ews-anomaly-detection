LLM_BASE_URL=https://manavgat.yzyonetim.zb/v1
LLM_API_KEY=<valid-key>
LLM_MODEL=gpt-oss-20b
# Optional. Internal endpoint'e proxy env ile gitmek zorundaysan true yap.
# LLM_HTTP_TRUST_ENV=false
# Optional. Kurum/internal CA bundle path'i.
# LLM_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt
# Optional. Default false; internal endpoint sertifika zinciri dogrulanmaz.
# LLM_SSL_VERIFY=false
# Optional: secret/secrets.yaml icindeki llm.sections anahtarini secmek icin.
# LLM_SECTION=OPENSHIFT_LLM
