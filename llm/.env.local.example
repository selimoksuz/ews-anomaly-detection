LLM_API_KEY=<valid-key>
LLM_MODEL=gpt-oss-20b
LLM_TIMEOUT_SECONDS=120
# Endpoint response_format desteklemiyorsa none yap.
LLM_RESPONSE_FORMAT=json_object
