# ============================================================================
# SECRET CONFIG EXAMPLE
# ============================================================================
# Bu dosya credential ve connection degerlerini tutar. Bu degerler config/pipeline_config.yaml
# icine konulmamalidir.
# Bu dosyayi secret/secrets.yaml olarak kopyalayip local/platform credential degerleriyle doldur.

oracle:
  # Oracle credential section listesi. config/pipeline_config.yaml icindeki oracle.section bu
  # adlara referans verir.
  sections:
    ORA_PRD_ZTUSER:
      # Direkt baglanti icin normal Oracle kullanicisi yazilir.
      # Proxy auth gerekiyorsa SQL*Plus formatini kullan: PROXY_USER[TARGET_SCHEMA]
      # oracledb tarafinda bu otomatik user=PROXY_USER, proxy_user=TARGET_SCHEMA olarak ayrilir.
      user: ''
      password: ''
      host: ''
      port: 1521
      # service_name kullaniliyorsa sid bos kalabilir.
      service_name: ''
      # sid kullaniliyorsa service_name bos kalabilir.
      sid: ''
